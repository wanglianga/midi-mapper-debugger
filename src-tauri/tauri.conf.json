{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "MIDI Mapper Debugger",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "all": true,
        "scope": ["$APPCONFIG/**", "$APPDATA/**", "$DOCUMENT/**", "$HOME/**"]
      },
      "dialog": {
        "all": true
      },
      "path": {
        "all": true
      },
      "window": {
        "all": true
      },
      "shell": {
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.midimapper.debugger",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "category": "Music",
      "shortDescription": "MIDI 设备映射调试工具",
      "longDescription": "为音乐制作人、现场调音师和硬件玩家设计的 MIDI 设备映射调试工具",
      "copyright": "© 2026 MIDI Mapper Debugger"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "MIDI Mapper Debugger",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": true,
        "transparent": false
      }
    ]
  }
}
